{
  "extends": "@repo/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "declaration": false,
    "sourceMap": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*"], //, "../../packages/types/src/dto/category.dto.ts
  "exclude": ["node_modules", "dist"]
}
